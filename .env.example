# ====================================
# Conscious Nepali — Environment Config
# Copy this file to .env and fill in your values
# ====================================

# Ghost Site URL (production)
GHOST_URL=https://consciousnepali.com

# Node environment: development | production
NODE_ENV=production

# MySQL Database
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_PASSWORD=change_this_ghost_password

# Mail Configuration (Mailgun recommended)
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=postmaster@mg.consciousnepali.com
MAIL_PASS=your_mailgun_smtp_password
MAIL_FROM=noreply@consciousnepali.com

# Ghost Admin (set after first run)
GHOST_ADMIN_EMAIL=sulav@consciousnepali.com
GHOST_ADMIN_NAME=Sulav Subedi
